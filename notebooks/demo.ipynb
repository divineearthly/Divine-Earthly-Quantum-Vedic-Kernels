    "## 3. AI Model Inference
",
    "Load the trained model and perform inference on new environmental data."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create some dummy new data for inference
",
    "new_data = pd.DataFrame({
",
    "    'timestamp': ['2023-01-01 13:00:00', '2023-01-01 14:00:00'],
",
    "    'temperature': [26.0, 30.0],
",
    "    'humidity': [65.0, 75.0],
",
    "    'air_quality': [85, 100],
",
    "    'soil_moisture': [0.6, 0.8],
",
    "    'light_intensity': [350, 200],
",
    "    'water_level': [11.0, 15.0],
",
    "    'vibration_intensity': [0.45, 0.8]
",
    "})
",
    "
",
    "print("Performing inference on new data...")
",
    "# The scaler and label_encoder are saved in the REPO_PATH/ai_layer by train_model.py
",
    "# We assume we are running this from REPO_PATH/ai_layer or they are copied to current working directory
",
    "# For this demo, let's assume the paths are relative to where the script was run or moved appropriately.
",
    "# For robustness, we should explicitly specify paths in predict function.
",
    "
",
    "# Let's adjust paths for robustness assuming execution from REPO_PATH/notebooks or any dir.
",
    "# Ensure joblib files are accessible. train_model.py saves them in its current directory, which is ai_layer.
",
    "# So, we should explicitly point to ai_layer for joblib artifacts.
",
    "joblib_scaler_path = os.path.join(REPO_PATH, 'ai_layer', 'scaler.pkl')
",
    "joblib_encoder_path = os.path.join(REPO_PATH, 'ai_layer', 'label_encoder.pkl')
",
    "
",
    "predictions = predict(MODEL_PATH, joblib_scaler_path, joblib_encoder_path, new_data)
",
    "print(f"Predicted labels for new data:
{new_data.assign(predicted_label=predictions)}")
"
   ]
